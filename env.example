# ============================================
# CRYPTO SCREENER - ENVIRONMENT VARIABLES
# ============================================

# --- App ---
NODE_ENV=production
# PORT is automatically provided by Railway — do NOT set manually
# API_PORT is the internal API port (default: 4000)
API_PORT=4000
FRONTEND_URL=https://your-app.up.railway.app

# --- Database (Railway PostgreSQL) ---
DATABASE_URL=postgresql://user:password@host:5432/dbname
DIRECT_URL=postgresql://user:password@host:5432/dbname

# --- Redis (Railway Redis) ---
REDIS_URL=redis://default:password@host:6379

# --- JWT ---
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# --- Telegram (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBAPP_URL=https://your-app.up.railway.app
TELEGRAM_BOT_WEBHOOK_SECRET=

# --- Exchange API Keys (optional, for higher rate limits) ---
BINANCE_API_KEY=
BINANCE_API_SECRET=
BYBIT_API_KEY=
BYBIT_API_SECRET=
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# --- Sentry (optional) ---
SENTRY_DSN=

# --- S3 / R2 Storage (optional) ---
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=crypto-screener

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# --- WebSocket ---
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_CONNECTIONS_PER_IP=10
